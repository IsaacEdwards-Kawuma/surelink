# ── SureLink WiFi Manager — Environment Config ──────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Server
# PORT: leave empty or omit on Render (Render sets it automatically). For local use: 3000
PORT=3000
NODE_ENV=production

# Security — change this to a long random string (50+ characters)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_min_50_chars

# Database path (SQLite file location)
DB_PATH=./db/surelink.db

# Backup settings
BACKUP_DIR=./backup/files
BACKUP_KEEP_DAYS=30

# Optional: admin alert email (for future notification features)
ADMIN_EMAIL=andrew@yourdomain.com

# Optional: Allowed origins for CORS (comma-separated)
# Leave blank to allow all (fine for private deployments)
ALLOWED_ORIGINS=
