# ── SureLink WiFi Manager — Environment Config ──────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets (DATABASE_URL, JWT_SECRET).
# Never share or paste these values in code, chat, or screenshots.

# Server
# PORT: leave empty or omit on Render (Render sets it automatically). For local use: 3000
PORT=3000
NODE_ENV=production

# Security — change this to a long random string (50+ characters)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_min_50_chars

# PostgreSQL (required). Keep this secret — never commit or share.
# Get from Neon/Render/Supabase dashboard. Example: postgresql://user:password@host/dbname
DATABASE_URL=

# Backup settings
BACKUP_DIR=./backup/files
BACKUP_KEEP_DAYS=30

# Optional: admin alert email (for future notification features)
ADMIN_EMAIL=andrew@yourdomain.com

# Optional: Allowed origins for CORS (comma-separated). Leave blank to allow all.
# If you get "CORS request did not succeed", leave empty or add your frontend URL (e.g. https://your-app.vercel.app)
ALLOWED_ORIGINS=
